# Database Configuration
DB_HOST=localhost
DB_USER=sapukota_user
DB_PASSWORD=your_secure_password_here
DB_NAME=sapukota

# JWT Secret (IMPORTANT: Generate a strong random string)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_long

# Server Configuration
PORT=5000
NODE_ENV=production

# Cloudinary Configuration (REQUIRED for Production - Railway/Vercel/etc)
# Sign up at https://cloudinary.com (FREE tier available)
# Get these from Cloudinary Dashboard → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Optional: CORS Configuration (if frontend on different domain)
# CORS_ORIGIN=https://yourdomain.com
