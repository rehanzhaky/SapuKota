# Frontend Environment Variables for Deployment

# ============================================
# API Configuration
# ============================================

# For local development (uses Vite proxy)
# VITE_API_URL=/api

# For Railway/Vercel/Render deployment
# Replace with your actual backend URL
VITE_API_URL=https://your-backend-url.railway.app/api

# Examples:
# Railway: https://sapukota-backend-production.up.railway.app/api
# Render: https://sapukota-backend.onrender.com/api
# Vercel: https://sapukota-backend.vercel.app/api

# ============================================
# Optional: Other Configs
# ============================================
# VITE_APP_NAME=SapuKota
# VITE_ENVIRONMENT=production
